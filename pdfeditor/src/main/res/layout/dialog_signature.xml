<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vẽ chữ ký của bạn"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1F2937"
        android:layout_marginBottom="12dp"/>

    <com.vandatgsts.pdfeditor.SignatureView
        android:id="@+id/dialogSignatureView"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#F3F4F6"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Màu mực:"
            android:textColor="#374151"
            android:textSize="14sp"
            android:layout_marginEnd="12dp"/>

        <View
            android:id="@+id/viewColorBlue"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:id="@+id/viewColorBlack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:id="@+id/viewColorRed"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <CheckBox
        android:id="@+id/cbSaveSignature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lưu chữ ký để dùng lại lần sau"
        android:textColor="#374151"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnDialogClear"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xóa nét vẽ"
            android:textColor="#EF4444"/>

        <Button
            android:id="@+id/btnDialogCancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hủy"
            android:textColor="#6B7280"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/btnDialogConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chèn chữ ký"
            android:backgroundTint="#059669"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainViewer3rd"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <!-- Header Toolbar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/headerToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:cardElevation="4dp"
        app:cardMaxElevation="4dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Quay lại"
                app:tint="#1F2937"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:layout_toStartOf="@id/btnCancelEdits"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:text="Xem Tài Liệu PDF (PDFView)"
                android:textColor="#1F2937"
                android:textSize="18sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/btnCancelEdits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/btnMenuTools"
                android:layout_marginEnd="8dp"
                android:layout_centerVertical="true"
                android:text="Hủy"
                android:backgroundTint="#EF4444"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:minHeight="36dp"
                android:minWidth="60dp"
                app:cornerRadius="6dp"/>

            <Button
                android:id="@+id/btnMenuTools"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/btnSaveEdits"
                android:layout_marginEnd="8dp"
                android:layout_centerVertical="true"
                android:text="Công cụ"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:minHeight="36dp"
                android:minWidth="60dp"
                app:cornerRadius="6dp"/>

            <Button
                android:id="@+id/btnSaveEdits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Lưu"
                android:backgroundTint="#059669"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="0dp"
                android:minHeight="36dp"
                android:minWidth="60dp"
                app:cornerRadius="6dp"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- PDFView & Overlay Container -->
    <FrameLayout
        android:id="@+id/pdfContainerLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <com.github.barteksc.pdfviewer.PDFView
            android:id="@+id/pdfView3rd"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Lớp phủ trong suốt có kích thước động khớp với trang hiển thị để chèn chữ ký/ảnh và Edit Text -->
        <FrameLayout
            android:id="@+id/pdfViewContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Bottom Navigation Bar (Page controller) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:cardElevation="8dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3">

            <Button
                android:id="@+id/btnPrevPage"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Trang trước"
                android:textColor="#2563EB"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvPageIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Trang 1 / 1"
                android:textColor="#4B5563"
                android:textSize="14sp"
                android:gravity="center"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnNextPage"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Trang sau"
                android:textColor="#2563EB"
                android:textSize="14sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
